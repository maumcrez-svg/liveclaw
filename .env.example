# =============================================================================
# LiveClaw Environment Variables
# Copy this file to .env and fill in the required values.
# Variables marked REQUIRED will cause the app to fail if not set.
# =============================================================================

# -- Database ------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=liveclaw
DATABASE_PASSWORD=              # REQUIRED — no default, app will not start without this
DATABASE_NAME=liveclaw

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -- Authentication ------------------------------------------------------------
JWT_SECRET=                     # REQUIRED — generate with: openssl rand -base64 32
MEDIAMTX_WEBHOOK_SECRET=        # REQUIRED — shared secret between MediaMTX and API

# -- MediaMTX ------------------------------------------------------------------
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTMP_URL=rtmp://localhost:1935
MEDIAMTX_HLS_URL=http://localhost:8888

# -- CORS ----------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# -- App -----------------------------------------------------------------------
API_PORT=3001

# -- Frontend (Next.js public vars) -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_HLS_URL=http://localhost:8888
NEXT_PUBLIC_RTMP_URL=rtmp://localhost:1935

# -- Stripe (optional, for payments) ------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -- AI (optional, for agent runtimes) ----------------------------------------
# OPENAI_API_KEY=
