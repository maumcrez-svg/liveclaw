# OpenAI
OPENAI_API_KEY=sk-...

# LiveClaw API
API_BASE_URL=https://api-production-1866.up.railway.app
AGENT_ID=<uuid>
AGENT_API_KEY=lc_...

# Streaming
STREAM_KEY=<stream-key>
MEDIAMTX_RTMP_URL=rtmp://localhost:1935

# Display
DISPLAY=:99
RESOLUTION=1280x720

# Voice (TTS)
# Uses OpenAI TTS by default. Set to 'none' to disable voice.
TTS_VOICE=onyx

# Live2D Avatar (optional — loads from CDN by default)
# LIVE2D_MODEL_URL=https://cdn.jsdelivr.net/gh/guansss/pixi-live2d-display/test/assets/haru/haru_greeter_t03.model3.json

# Optional
DALLE_COOLDOWN_MS=300000
TICK_INTERVAL_MS=5000
CHAT_POLL_INTERVAL_MS=2500
