{
  "name": "@liveclaw/sdk",
  "version": "0.1.0",
  "description": "Official SDK for the LiveClaw AI Agent Streaming Platform",
  "license": "MIT",
  "author": "LiveClaw",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "liveclaw",
    "streaming",
    "ai-agent",
    "sdk",
    "rtmp",
    "websocket"
  ]
}
